<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/emdco#"
     xml:base="http://www.example.org/emdco"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:emdco="http://www.example.org/emdco#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://www.example.org/emdco">
        <dc:creator>Miguel Ángel Gata Luján</dc:creator>
        <dc:description>Ontology modelling the European catalogue of medical devices and in vitro diagnostics under MDR (EU 2017/745) and IVDR (EU 2017/746) regulatory frameworks, including manufacturers, risks, incidents and field safety corrective actions registered in EUDAMED.</dc:description>
        <dc:title>European Medical Device Catalogue Ontology (EMDCO)</dc:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#ID -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#ID"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument1 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument1"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument2 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument2"/>
    


    <!-- http://www.w3.org/2003/11/swrl#body -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#body"/>
    


    <!-- http://www.w3.org/2003/11/swrl#classPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#classPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#head -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#head"/>
    


    <!-- http://www.w3.org/2003/11/swrl#propertyPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#propertyPredicate"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#addressesIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:comment>Relates a field safety corrective action to the incident it addresses.</rdfs:comment>
        <rdfs:label>addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasActionType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasActionType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#ActionType"/>
        <rdfs:comment>Relates an FSCA to its type of corrective action.</rdfs:comment>
        <rdfs:label>has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasCompetentAuthority -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasCompetentAuthority">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#CompetentAuthority"/>
        <rdfs:comment>Relates a manufacturer to the national competent authority that supervises it.</rdfs:comment>
        <rdfs:label>has competent authority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Country"/>
        <rdfs:comment>Relates a manufacturer to the country where it is registered.</rdfs:comment>
        <rdfs:label>has country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasRegulatoryFramework">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#RegulatoryFramework"/>
        <rdfs:comment>Relates a medical device to the EU regulation under which it is classified.</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment>Relates a medical device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasSeverity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#SeverityLevel"/>
        <rdfs:comment>Relates a risk to its severity level.</rdfs:comment>
        <rdfs:label>has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#hasStatus -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#FSCAStatus"/>
        <rdfs:comment>Relates an FSCA to its current status.</rdfs:comment>
        <rdfs:label>has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#involvesDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:comment>Relates an incident to the medical device involved.</rdfs:comment>
        <rdfs:label>involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#isManufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#isManufacturedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:comment>Relates a medical device to its registered manufacturer.</rdfs:comment>
        <rdfs:label>is manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#isRelatedToRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#isRelatedToRisk">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:comment>Relates an incident to the risk that materialised.</rdfs:comment>
        <rdfs:label>is related to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdco#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdco#reportedBy">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:comment>Relates an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#hasActionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasActionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the FSCA was initiated.</rdfs:comment>
        <rdfs:label>has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasAuthorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official registration number issued by the competent authority.</rdfs:comment>
        <rdfs:label>has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasClosureDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the FSCA was closed.</rdfs:comment>
        <rdfs:label>has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasContactEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The regulatory contact email of the manufacturer.</rdfs:comment>
        <rdfs:label>has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasCorrectiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasCorrectiveActionTaken">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether a corrective action was taken following the incident.</rdfs:comment>
        <rdfs:label>has corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A textual description of the entity.</rdfs:comment>
        <rdfs:label>has description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasDeviceID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasDeviceID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique identifier of the medical device.</rdfs:comment>
        <rdfs:label>has device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasDeviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The commercial name of the medical device.</rdfs:comment>
        <rdfs:label>has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasDevicesAffectedCount -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasDevicesAffectedCount">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The number of devices affected by the FSCA.</rdfs:comment>
        <rdfs:label>has devices affected count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasEUDAMEDFSCARef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasEUDAMEDFSCARef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The EUDAMED reference number for the FSCA.</rdfs:comment>
        <rdfs:label>has EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasEUDAMEDSRN -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasEUDAMEDSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The Single Registration Number assigned in EUDAMED.</rdfs:comment>
        <rdfs:label>has EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasEventDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasEventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the incident event occurred.</rdfs:comment>
        <rdfs:label>has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasFSCAID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasFSCAID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique identifier of the field safety corrective action.</rdfs:comment>
        <rdfs:label>has FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasIMDRFCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasIMDRFCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The IMDRF terminology code identifying the risk type.</rdfs:comment>
        <rdfs:label>has IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasIncidentID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasIncidentID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique identifier of the incident.</rdfs:comment>
        <rdfs:label>has incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasIntendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The clinical use for which the device is intended.</rdfs:comment>
        <rdfs:label>has intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasManufacturerID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasManufacturerID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique identifier of the manufacturer.</rdfs:comment>
        <rdfs:label>has manufacturer ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The legal name of the manufacturer.</rdfs:comment>
        <rdfs:label>has name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasOutcome">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The clinical outcome of the incident.</rdfs:comment>
        <rdfs:label>has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasPatientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasPatientAge">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>has patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasPatientSex -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasPatientSex">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The sex of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>has patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasReportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the incident was reported to the competent authority.</rdfs:comment>
        <rdfs:label>has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasRiskID -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasRiskID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique identifier of the risk.</rdfs:comment>
        <rdfs:label>has risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasRiskName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasRiskName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the risk as defined in the IMDRF terminology.</rdfs:comment>
        <rdfs:label>has risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasScope -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasScope">
        <rdfs:domain rdf:resource="http://www.example.org/emdco#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of the devices or lots affected by the FSCA.</rdfs:comment>
        <rdfs:label>has scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#hasUDI -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#hasUDI">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The Unique Device Identifier (UDI-DI) assigned to the device.</rdfs:comment>
        <rdfs:label>has UDI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device requires an energy source to operate.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isIVD">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is an in vitro diagnostic device.</rdfs:comment>
        <rdfs:label>is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is implantable.</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdco#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdco#isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device can be used more than once.</rdfs:comment>
        <rdfs:label>is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdco#ActionType -->


    <owl:Class rdf:about="http://www.example.org/emdco#ActionType">
        <rdfs:comment>The type of field safety corrective action taken by a manufacturer.</rdfs:comment>
        <rdfs:label>Action Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:comment>A medical device whose operation depends on a source of energy other than that generated by the human body.</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ActiveImplant -->


    <owl:Class rdf:about="http://www.example.org/emdco#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActiveDevice"/>
        <rdfs:comment>An active device that is intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassA -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassA">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment>Lowest risk class under IVDR.</rdfs:comment>
        <rdfs:label>Class A</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassB -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassB">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment>Low-medium risk class under IVDR.</rdfs:comment>
        <rdfs:label>Class B</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassC -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassC">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment>Medium-high risk class under IVDR.</rdfs:comment>
        <rdfs:label>Class C</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassD -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassD">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#IVDRRiskClass"/>
        <rdfs:comment>Highest risk class under IVDR.</rdfs:comment>
        <rdfs:label>Class D</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassI -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment>Lowest risk class under MDR.</rdfs:comment>
        <rdfs:label>Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassIII -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment>Highest risk class under MDR.</rdfs:comment>
        <rdfs:label>Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassIIa -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment>Medium-low risk class under MDR.</rdfs:comment>
        <rdfs:label>Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ClassIIb -->


    <owl:Class rdf:about="http://www.example.org/emdco#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment>Medium-high risk class under MDR.</rdfs:comment>
        <rdfs:label>Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Closed -->


    <owl:Class rdf:about="http://www.example.org/emdco#Closed">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FSCAStatus"/>
        <owl:disjointWith rdf:resource="http://www.example.org/emdco#Open"/>
        <rdfs:comment>The FSCA has been completed and closed.</rdfs:comment>
        <rdfs:label>Closed</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#CompetentAuthority -->


    <owl:Class rdf:about="http://www.example.org/emdco#CompetentAuthority">
        <rdfs:comment>The national regulatory body responsible for supervising medical devices in a given EU member state.</rdfs:comment>
        <rdfs:label>Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Country -->


    <owl:Class rdf:about="http://www.example.org/emdco#Country">
        <rdfs:comment>A country in which a manufacturer is registered or an incident has been reported.</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#CriticalSeverity -->


    <owl:Class rdf:about="http://www.example.org/emdco#CriticalSeverity">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#SeverityLevel"/>
        <rdfs:comment>Risk event that could directly cause death or irreversible harm.</rdfs:comment>
        <rdfs:label>Critical Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#FSCA -->


    <owl:Class rdf:about="http://www.example.org/emdco#FSCA">
        <rdfs:comment>A corrective action taken by a manufacturer to reduce risk of death or serious deterioration in health associated with a device in the field.</rdfs:comment>
        <rdfs:label>Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#FSCAStatus -->


    <owl:Class rdf:about="http://www.example.org/emdco#FSCAStatus">
        <rdfs:comment>The current status of a field safety corrective action.</rdfs:comment>
        <rdfs:label>FSCA Status</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#IVDR -->


    <owl:Class rdf:about="http://www.example.org/emdco#IVDR">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RegulatoryFramework"/>
        <owl:disjointWith rdf:resource="http://www.example.org/emdco#MDR"/>
        <rdfs:comment>EU In Vitro Diagnostic Regulation 2017/746.</rdfs:comment>
        <rdfs:label>IVDR</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#IVDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.example.org/emdco#MDRRiskClass"/>
        <rdfs:comment>Risk class under EU IVDR 2017/746.</rdfs:comment>
        <rdfs:label>IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ImplantableDevice"/>
        <rdfs:comment>An active medical device intended to be totally or partially introduced into the human body.</rdfs:comment>
        <rdfs:label>Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#hasRiskClass"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A medical device intended to be totally or partially introduced into the human body and to remain there after the procedure.</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InSituCorrection -->


    <owl:Class rdf:about="http://www.example.org/emdco#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActionType"/>
        <rdfs:comment>Correction of a device at the user&apos;s location.</rdfs:comment>
        <rdfs:label>In-Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:comment>A medical device intended to examine specimens derived from the human body for diagnostic purposes, as defined under IVDR 2017/746.</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Incident -->


    <owl:Class rdf:about="http://www.example.org/emdco#Incident">
        <rdfs:comment>A reportable event involving a medical device that has or could have led to patient harm, as defined under EU MDR Article 87.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MDR -->


    <owl:Class rdf:about="http://www.example.org/emdco#MDR">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RegulatoryFramework"/>
        <rdfs:comment>EU Medical Device Regulation 2017/745.</rdfs:comment>
        <rdfs:label>MDR</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#RiskClass"/>
        <rdfs:comment>Risk class under EU MDR 2017/745.</rdfs:comment>
        <rdfs:label>MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Manufacturer -->


    <owl:Class rdf:about="http://www.example.org/emdco#Manufacturer">
        <rdfs:comment>A legal entity that manufactures or places on the EU market a medical device and bears responsibility for its conformity.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#MedicalDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#MedicalDevice">
        <rdfs:comment>A medical device as defined under EU MDR 2017/745 or IVDR 2017/746, registered in EUDAMED.</rdfs:comment>
        <rdfs:label>Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#ModerateSeverity -->


    <owl:Class rdf:about="http://www.example.org/emdco#ModerateSeverity">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#SeverityLevel"/>
        <rdfs:comment>Risk event that causes moderate harm requiring medical intervention.</rdfs:comment>
        <rdfs:label>Moderate Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Open -->


    <owl:Class rdf:about="http://www.example.org/emdco#Open">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#FSCAStatus"/>
        <rdfs:comment>The FSCA is still ongoing.</rdfs:comment>
        <rdfs:label>Open</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Recall -->


    <owl:Class rdf:about="http://www.example.org/emdco#Recall">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActionType"/>
        <rdfs:comment>Removal of a device from the market or from use.</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#RegulatoryFramework -->


    <owl:Class rdf:about="http://www.example.org/emdco#RegulatoryFramework">
        <rdfs:comment>The EU regulation under which a medical device is classified and registered.</rdfs:comment>
        <rdfs:label>Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#Risk -->


    <owl:Class rdf:about="http://www.example.org/emdco#Risk">
        <rdfs:comment>A potential hazard associated with a medical device, classified according to IMDRF terminology.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#RiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdco#RiskClass">
        <rdfs:comment>The regulatory risk classification assigned to a medical device based on its intended purpose and associated risks.</rdfs:comment>
        <rdfs:label>Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SafetyAlert -->


    <owl:Class rdf:about="http://www.example.org/emdco#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActionType"/>
        <rdfs:comment>Communication to users regarding a safety issue.</rdfs:comment>
        <rdfs:label>Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SelfTestDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#InVitroDiagnosticDevice"/>
        <rdfs:comment>An in vitro diagnostic device intended to be used by lay persons in a home environment.</rdfs:comment>
        <rdfs:label>Self-Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/emdco#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#Incident"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdco#isRelatedToRisk"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>An incident that directly or indirectly led to death, serious deterioration of health, or a serious public health threat.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SeriousSeverity -->


    <owl:Class rdf:about="http://www.example.org/emdco#SeriousSeverity">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#SeverityLevel"/>
        <rdfs:comment>Risk event that causes serious but potentially reversible harm.</rdfs:comment>
        <rdfs:label>Serious Severity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SeverityLevel -->


    <owl:Class rdf:about="http://www.example.org/emdco#SeverityLevel">
        <rdfs:comment>The degree of harm or impact associated with a risk event.</rdfs:comment>
        <rdfs:label>Severity Level</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#SingleUseDevice -->


    <owl:Class rdf:about="http://www.example.org/emdco#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#MedicalDevice"/>
        <rdfs:comment>A device intended to be used on one individual during a single procedure.</rdfs:comment>
        <rdfs:label>Single-Use Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdco#UserNotice -->


    <owl:Class rdf:about="http://www.example.org/emdco#UserNotice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdco#ActionType"/>
        <rdfs:comment>Notice to users with instructions to avoid or mitigate risk.</rdfs:comment>
        <rdfs:label>User Notice</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://dbpedia.org/resource/Germany -->


    <owl:NamedIndividual rdf:about="http://dbpedia.org/resource/Germany">
        <owl:sameAs rdf:resource="http://www.example.org/emdco#Germany"/>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#Germany -->


    <rdf:Description rdf:about="http://www.example.org/emdco#Germany"/>
    


    <!-- http://dbpedia.org/resource/Ireland -->


    <owl:NamedIndividual rdf:about="http://dbpedia.org/resource/Ireland">
        <owl:sameAs rdf:resource="http://www.example.org/emdco#Ireland"/>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#Ireland -->


    <rdf:Description rdf:about="http://www.example.org/emdco#Ireland"/>
    


    <!-- http://www.example.org/emdco#Abbott -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#Abbott">
        <rdf:type rdf:resource="http://www.example.org/emdco#Manufacturer"/>
        <hasCompetentAuthority rdf:resource="http://www.example.org/emdco#BfArM"/>
        <hasCountry rdf:resource="http://www.example.org/emdco#Germany"/>
        <hasAuthorizationNumber>DE/2017/005678</hasAuthorizationNumber>
        <hasContactEmail>regulatory@abbott.com</hasContactEmail>
        <hasEUDAMEDSRN>SRN-DE-MED-0002</hasEUDAMEDSRN>
        <hasManufacturerID>MAN-002</hasManufacturerID>
        <hasName>Abbott Medical Devices</hasName>
        <rdfs:label>Abbott Medical Devices</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#BfArM -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#BfArM">
        <rdf:type rdf:resource="http://www.example.org/emdco#CompetentAuthority"/>
        <rdfs:comment>Bundesinstitut für Arzneimittel und Medizinprodukte - German competent authority for medical devices.</rdfs:comment>
        <rdfs:label>BfArM</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#ClassC_inst -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#ClassC_inst">
        <rdf:type rdf:resource="http://www.example.org/emdco#ClassC"/>
        <rdfs:label>Class C</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#ClassIII_inst -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#ClassIII_inst">
        <rdf:type rdf:resource="http://www.example.org/emdco#ClassIII"/>
        <rdfs:label>Class III</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#Closed_inst -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#Closed_inst">
        <rdf:type rdf:resource="http://www.example.org/emdco#Closed"/>
        <rdfs:label>Closed</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#CobasE801 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#CobasE801">
        <rdf:type rdf:resource="http://www.example.org/emdco#InVitroDiagnosticDevice"/>
        <hasRegulatoryFramework rdf:resource="http://www.example.org/emdco#IVDR_inst"/>
        <hasRiskClass rdf:resource="http://www.example.org/emdco#ClassC_inst"/>
        <isManufacturedBy rdf:resource="http://www.example.org/emdco#Roche"/>
        <hasDeviceID>DEV-016</hasDeviceID>
        <hasDeviceName>cobas e 801 Immunoassay Analyzer</hasDeviceName>
        <hasIntendedPurpose>Automated immunoassay analyzer for clinical laboratory</hasIntendedPurpose>
        <hasUDI>(01)04015630001016</hasUDI>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isIVD rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isIVD>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isImplantable>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isReusable>
        <rdfs:label>cobas e 801 Immunoassay Analyzer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/emdco#CriticalSeverity_inst -->


    <owl:NamedIndividual rdf:about="http://www.example.org/emdco#CriticalSeverity_inst">
        <rdf:type rdf:resource="http://www.example.org/emdco#CriticalSeverity"/>
        <rdfs:label>Critical</rdfs:label>
